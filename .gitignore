# =============================================================
# ROOT .gitignore — polyglot-todo-app monorepo
# Covers: Node.js, NestJS, Express, React, React Native (Expo),
#         Python / FastAPI, Java / Spring Boot (Maven)
# =============================================================

# -------------------------------------------------------------
# macOS
# -------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# -------------------------------------------------------------
# IDE / Editor
# -------------------------------------------------------------
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.code-workspace

# -------------------------------------------------------------
# Node.js  (Express · NestJS · React · React Native)
# -------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/
.yarn/

# Build output
dist/
build/
out/
.next/
.nuxt/

# Runtime / cache
.cache/
.turbo/
.parcel-cache/

# Environment files  (keep .env.example / env.example)
.env
.env.*
!.env.example
!env.example

# -------------------------------------------------------------
# TypeScript
# -------------------------------------------------------------
*.tsbuildinfo

# -------------------------------------------------------------
# Testing
# -------------------------------------------------------------
coverage/
.nyc_output/
test-results/
playwright-report/

# -------------------------------------------------------------
# Python / FastAPI
# -------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.whl
MANIFEST

# Virtual environments
venv/
.venv/
env/
.env/
ENV/
.virtualenv/

# Pytest
.pytest_cache/
htmlcov/
.coverage
.coverage.*
*.cover

# MyPy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/

# -------------------------------------------------------------
# Java / Spring Boot (Maven)
# -------------------------------------------------------------
target/
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*

# Maven wrapper (generated — not needed in VCS)
.mvn/wrapper/maven-wrapper.jar

# Spring Boot
*.log
logs/

# -------------------------------------------------------------
# Docker
# -------------------------------------------------------------
.dockerignore

# -------------------------------------------------------------
# Miscellaneous
# -------------------------------------------------------------
*.bak
*.tmp
*.temp
*.orig
Thumbs.db
