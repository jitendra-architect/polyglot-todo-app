APP_ENV=development
PORT=8000

# Database selector: mongodb (default) or postgresql
DB_PROFILE=mongodb

# MongoDB (required when DB_PROFILE=mongodb)
MONGODB_URI=mongodb://localhost:27017/todos

# PostgreSQL (required when DB_PROFILE=postgresql)
POSTGRESQL_URI=postgresql+asyncpg://postgres:postgres@localhost:5432/todos

# Redis — optional caching + background jobs
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Alternatively set a full URL (takes precedence over HOST+PORT)
REDIS_URL=

# Cache TTL in seconds
CACHE_TTL_SECONDS=30
