{
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": [
      {
        "include": "**/*.ejs",
        "outDir": "dist/views"
      },
      {
        "include": "../public/**/*",
        "outDir": "dist/public"
      }
    ],
    "deleteOutDir": true
  }
}


