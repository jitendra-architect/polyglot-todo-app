NODE_ENV=development
PORT=3000

# Database selector: mongodb (default) or postgresql
DB_PROFILE=mongodb

# MongoDB (required when DB_PROFILE=mongodb)
MONGODB_URI=mongodb://localhost:27017/todos

# PostgreSQL (required when DB_PROFILE=postgresql)
POSTGRESQL_URI=postgresql://postgres:postgres@localhost:5432/todos

# Redis (optional caching and jobs)
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Alternatively, use REDIS_URL=redis://:password@host:port
REDIS_URL=

# Cache TTL (seconds)
CACHE_TTL_SECONDS=30


